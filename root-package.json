{
  "name": "galaxy-ideas-economy",
  "version": "1.0.0",
  "private": true,
  "description": "مجرة اقتصاد الأفكار — نظام إيكولوجي رقمي إنساني من 14 كوكباً",
  "author": "جميل العديني",
  "license": "CC-BY-4.0",
  "packageManager": "pnpm@9.12.0",
  "engines": {
    "node": ">=20.0.0",
    "pnpm": ">=9.0.0"
  },
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "test": "turbo run test",
    "format": "prettier --write \"**/*.{js,jsx,ts,tsx,json,md,css}\"",
    "clean": "turbo run clean && rm -rf node_modules",
    "new:planet": "bash scripts/new-planet.sh",
    "deploy:apps": "turbo run build && firebase deploy --only hosting",
    "deploy:functions": "turbo run build --filter=@galaxy/functions && firebase deploy --only functions",
    "deploy:rules": "firebase deploy --only firestore:rules,firestore:indexes,storage"
  },
  "devDependencies": {
    "turbo": "^2.1.0",
    "prettier": "^3.3.3",
    "typescript": "^5.6.0",
    "firebase-tools": "^13.20.0"
  }
}
